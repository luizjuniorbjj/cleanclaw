# ============================================
# CleanClaw — Environment Configuration
# ============================================
# Copy to .env.cleanclaw and fill in actual values
# DO NOT commit .env.cleanclaw with real credentials
# ============================================

# --------------------------------------------
# Database & Cache
# --------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/clawtobusiness
REDIS_URL=redis://localhost:6379/0

# --------------------------------------------
# Security
# --------------------------------------------
SECRET_KEY=change-me-to-a-random-string

# --------------------------------------------
# CleanClaw Service
# --------------------------------------------
CLEANCLAW_PORT=8003
CLEANCLAW_CORS_ORIGINS=http://localhost:3000,http://localhost:8003
CLEANCLAW_DEFAULT_PLAN=basic
CLEANCLAW_AUTO_SCHEDULE_TIME=18:00

# --------------------------------------------
# Stripe (Billing)
# --------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --------------------------------------------
# Google OAuth
# --------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --------------------------------------------
# Twilio (SMS Notifications)
# --------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --------------------------------------------
# Web Push (VAPID)
# --------------------------------------------
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@cleanclaw.com

# --------------------------------------------
# Debug
# --------------------------------------------
DEBUG=false
LOG_LEVEL=INFO
